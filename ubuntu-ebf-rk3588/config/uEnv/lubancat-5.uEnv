overlays=rk3588-lubancat-5-hdmi0-overlay rk3588-lubancat-5-hdmi1-vp2-overlay

# 正确的方法是将所有需要的设备树覆盖文件名列在一个overlays=后面，用空格分隔。例如：
# 下面是为鲁班猫5使用两个覆盖层的示例:      
# overlays=overlays=rk3588-lubancat-5-hdmi0-overlay rk3588-lubancat-5-hdmi1-vp2-overlay

#40pin
# rk3588-lubancat-i2c3-m0-overlay
# rk3588-lubancat-i2c4-m3-overlay
# rk3588-lubancat-uart3-m0-overlay
# rk3588-lubancat-uart1-m1-overlay
# rk3588-lubancat-spi0-m1-overlay
# rk3588-lubancat-i2c8-m2-overlay
# rk3588-lubancat-pwm0-m2-overlay
